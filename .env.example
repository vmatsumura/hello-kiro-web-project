# Portal do Automóvel — Environment Variables
# Copy this file to .env.local and fill in the values.
# All VITE_ variables are PUBLIC and bundled into the client build.
# Never put secrets or API keys in VITE_ variables.

# Site URL (used for SEO and canonical links)
VITE_SITE_URL=https://auto-compara-portal.vercel.app

# Analytics (optional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
